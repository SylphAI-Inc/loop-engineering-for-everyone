    {"type":"text","id":"good-items","x":460,"y":95,"width":330,"height":180,"text":"Goal: 'Fix 3 broken links' (measurable)\n\nWorker: Coding agent, scoped to docs/\n\nVerification: markdown-link-check\n\nStop: 3 pass OR 5 iters OR $2\n\nState: Git branch + progress.json\n\nHuman gate: Review diff before commit\n\nCost control: $2 cap, 5 iteration max","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","fillStyle":"solid","backgroundColor":"transparent","strokeColor":"#495057","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":["good"],"roundness":null,"seed":22,"version":1,"versionNonce":8,"isDeleted":false,"boundElements":null,"link":null,"locked":false},
    {"type":"text","id":"good-outcome","x":460,"y":300,"width":330,"height":70,"text":"Outcome: 3-line diff, $0.45 cost,\n2 minutes, fully reviewable,\ncrash-safe (git checkpoint)","fontSize":12,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","fillStyle":"solid","backgroundColor":"#d3f9d8","strokeColor":"#2b8a3e","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":["good"],"roundness":null,"seed":23,"version":1,"versionNonce":9,"isDeleted":false,"boundElements":null,"link":null,"locked":false},
    {"type":"text","id":"footer","x":150,"y":400,"width":540,"height":16,"text":"The difference is not the model \u2014 it's the loop design.","fontSize":13,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","fillStyle":"solid","backgroundColor":"transparent","strokeColor":"#495057","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":[],"roundness":null,"seed":30,"version":1,"versionNonce":10,"isDeleted":false,"boundElements":null,"link":null,"locked":false}
