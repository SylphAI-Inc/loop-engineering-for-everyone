    {"type":"text","id":"bad-items","x":50,"y":95,"width":330,"height":180,"text":"Goal: 'Make it look better'\n\nWorker: One agent, all tools, no scope\n\nVerification: None (agent self-judges)\n\nStop condition: None\n\nState: Context window only\n\nHuman gate: None\n\nCost control: None","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","fillStyle":"solid","backgroundColor":"transparent","strokeColor":"#495057","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":["bad"],"roundness":null,"seed":12,"version":1,"versionNonce":4,"isDeleted":false,"boundElements":null,"link":null,"locked":false},
    {"type":"text","id":"bad-outcome","x":50,"y":300,"width":330,"height":70,"text":"Outcome: 40-file diff, $50 cost,\n2 hours unattended, unreviewable,\ncrash = total loss","fontSize":12,"fontFamily":1,"textAlign":"center","verticalAlign":"middle","fillStyle":"solid","backgroundColor":"#ffe3e3","strokeColor":"#c92a2a","strokeWidth":1,"roughness":0,"opacity":100,"groupIds":["bad"],"roundness":null,"seed":13,"version":1,"versionNonce":5,"isDeleted":false,"boundElements":null,"link":null,"locked":false},
